---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  author?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  pubDate,
  author = 'Joseph Mulindwa',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const fullTitle =
  Astro.url.pathname === '/'
    ? `${title}`
    : `${title} — Affinity Travelling Blog`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Affinity Travelling" />
    {pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {pubDate && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --navy: #1e3a5f;
        --navy-dark: #142a47;
        --gold: #d4a853;
        --gold-dark: #b68a3a;
        --ink: #1a1a1a;
        --muted: #5a5a5a;
        --paper: #fdfcfa;
        --rule: #e8e4dc;
        --link: #1e3a5f;
        --link-hover: #d4a853;
        --serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
        --sans:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-size: 17px;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--serif);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      header.site {
        border-bottom: 1px solid var(--rule);
        background: white;
      }

      header.site .inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--sans);
      }

      header.site a.brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--navy);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.05rem;
      }

      header.site a.brand svg {
        flex-shrink: 0;
      }

      header.site nav a {
        color: var(--ink);
        text-decoration: none;
        font-size: 0.92rem;
        margin-left: 1.5rem;
        font-weight: 500;
      }

      header.site nav a:hover {
        color: var(--gold-dark);
      }

      main {
        padding: 3rem 0 4rem;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--sans);
        color: var(--navy);
        line-height: 1.25;
        margin-top: 2.4rem;
        margin-bottom: 0.8rem;
        font-weight: 600;
      }

      h1 {
        font-size: 2.1rem;
        letter-spacing: -0.015em;
        margin-top: 0.5rem;
      }

      h2 {
        font-size: 1.45rem;
        letter-spacing: -0.01em;
      }

      h3 {
        font-size: 1.18rem;
      }

      p {
        margin: 0 0 1.1rem;
      }

      a {
        color: var(--link);
        text-decoration: underline;
        text-decoration-color: rgba(30, 58, 95, 0.35);
        text-underline-offset: 0.18em;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--link-hover);
        text-decoration-color: var(--gold);
      }

      strong {
        color: var(--navy-dark);
      }

      hr {
        border: 0;
        border-top: 1px solid var(--rule);
        margin: 2.4rem 0;
      }

      ul,
      ol {
        padding-left: 1.4rem;
        margin: 0 0 1.2rem;
      }

      li {
        margin-bottom: 0.4rem;
      }

      blockquote {
        border-left: 3px solid var(--gold);
        padding-left: 1.1rem;
        margin: 1.5rem 0;
        color: var(--muted);
        font-style: italic;
      }

      code {
        background: #f3efe7;
        padding: 0.1em 0.35em;
        border-radius: 3px;
        font-size: 0.92em;
        font-family: 'SFMono-Regular', Menlo, Consolas, monospace;
      }

      .meta {
        font-family: var(--sans);
        font-size: 0.92rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
      }

      .meta .sep {
        margin: 0 0.55rem;
        color: var(--rule);
      }

      .lede {
        font-size: 1.08rem;
        color: var(--muted);
        font-style: italic;
        margin-bottom: 2rem;
      }

      .cta-box {
        background: linear-gradient(180deg, #f7f3ea 0%, #f1ead8 100%);
        border: 1px solid var(--gold);
        padding: 1.4rem 1.5rem;
        margin: 2.4rem 0;
        border-radius: 6px;
        font-family: var(--sans);
      }

      .cta-box h3 {
        font-size: 1.08rem;
        margin: 0 0 0.5rem;
      }

      .cta-box p {
        font-size: 0.95rem;
        margin: 0 0 0.9rem;
        color: var(--ink);
      }

      .cta-button {
        display: inline-block;
        background: var(--navy);
        color: white;
        padding: 0.65rem 1.15rem;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
      }

      .cta-button:hover {
        background: var(--navy-dark);
        color: white;
      }

      footer.site {
        border-top: 1px solid var(--rule);
        padding: 2rem 0;
        font-family: var(--sans);
        font-size: 0.88rem;
        color: var(--muted);
        text-align: center;
      }

      footer.site a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 0.6rem;
      }

      footer.site a:hover {
        color: var(--navy);
      }

      @media (max-width: 540px) {
        html {
          font-size: 16px;
        }
        h1 {
          font-size: 1.7rem;
        }
        h2 {
          font-size: 1.3rem;
        }
        main {
          padding: 2rem 0 3rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <a href="/" class="brand">
          <svg width="28" height="28" viewBox="0 0 64 64" aria-hidden="true">
            <rect width="64" height="64" rx="14" fill="#1E3A5F"></rect>
            <path d="M 52 14 L 12 30 L 32 32 L 24 52 Z" fill="#D4A853"></path>
            <path d="M 32 32 L 24 52 L 22 38 Z" fill="#B68A3A"></path>
          </svg>
          <span>Affinity Travelling</span>
        </a>
        <nav>
          <a href="/">Blog</a>
          <a href="https://www.affinitytravelling.com">The App</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div>
        <a href="https://www.affinitytravelling.com">Home</a>
        <a href="https://www.affinitytravelling.com/privacy">Privacy</a>
        <a href="https://www.affinitytravelling.com/terms">Terms</a>
        <a href="https://play.google.com/store/apps/details?id=com.affinitytravelling.app">Get the App</a>
      </div>
      <div style="margin-top: 1rem;">
        © {new Date().getFullYear()} Affinity Travelling. An independent document organizer — not affiliated with UDI, VFS Global, or any government body.
      </div>
    </footer>
  </body>
</html>
